{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "tnine-paypoint-demo"
      }
    }
  ],
  "services": {
    "tnine-paypoint-demo": {
      "root": ".",
      "entrypoint": "api/index.js",
      "framework": "express",
      "buildCommand": "npm ci && npm run db:generate && npm run db:deploy"
    }
  }
}
